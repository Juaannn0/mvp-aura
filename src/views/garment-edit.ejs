<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AURA — Editar prenda</title>
  <link rel="stylesheet" href="/css/main.css">
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<body>

  <main class="app-container">
    <div class="garment-form-page">

      <a href="/garments" class="garment-form-page__back">
        <svg viewBox="0 0 24 24"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Guardarropa
      </a>

      <h1 class="garment-form-page__title">Editar prenda</h1>

      <form class="garment-form" method="POST" action="/garments/edit/<%= garment.id %>" enctype="multipart/form-data">

        <!-- Imagen actual o upload nuevo -->
        <div class="form-field">
          <label>Foto</label>
          <div class="upload-zone" id="uploadZone">
            <input type="file" name="image" accept="image/*" id="imageInput">

            <% if (garment.image_path) { %>
              <img
                class="upload-preview"
                id="uploadPreview"
                src="/<%= garment.image_path %>"
                alt="<%= garment.name %>"
                style="display:block;"
              >
            <% } else { %>
              <i data-lucide="camera" class="upload-zone__icon"></i>
              <span class="upload-zone__text">Toca para agregar una foto</span>
              <span class="upload-zone__hint">JPG, PNG o WEBP</span>
              <img class="upload-preview" id="uploadPreview" alt="Preview">
            <% } %>
          </div>
        </div>

        <!-- Nombre -->
        <div class="form-field">
          <label for="name">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            value="<%= garment.name %>"
            required
          >
        </div>

        <!-- Categoría -->
        <div class="form-field form-field--select">
          <label for="category">Categoría</label>
          <select id="category" name="category" required>
            <option value="" disabled>Selecciona una categoría</option>
            <option value="tops"        <%= garment.category === 'tops'        ? 'selected' : '' %>>Parte superior</option>
            <option value="bottoms"     <%= garment.category === 'bottoms'     ? 'selected' : '' %>>Parte inferior</option>
            <option value="shoes"       <%= garment.category === 'shoes'       ? 'selected' : '' %>>Zapatos</option>
            <option value="accessories" <%= garment.category === 'accessories' ? 'selected' : '' %>>Accesorios</option>
            <option value="tshirts"   <%= garment.category === 'tshirts'   ? 'selected' : '' %>>Camiseta</option>
          </select>
        </div>

        <!-- Color -->
        <div class="form-field">
          <label>Color</label>
          <div class="color-picker-row">
            <input type="color" name="colorPicker" id="colorPicker" value="<%= garment.color || '#1a1a1a' %>">
            <input type="text"  name="color"       id="colorText"   value="<%= garment.color || '#1a1a1a' %>" placeholder="#000000">
          </div>
        </div>

        <!-- Acciones -->
        <div class="form-actions">
          <button type="submit" class="btn-primary">Guardar cambios</button>
          <a href="/garments" class="btn-ghost">Cancelar</a>
        </div>

      </form>

      <!-- Eliminar (fuera del form de edición) -->
      <form
        method="POST"
        action="/garments/delete/<%= garment.id %>"
        style="margin-top: 12px; padding-bottom: 40px;"
        onsubmit="return confirm('¿Eliminar <%= garment.name %> de tu guardarropa?')"
      >
        <button type="submit" class="btn-danger">Eliminar del guardarropa</button>
      </form>

    </div>
  </main>

  <script>
    const picker = document.getElementById('colorPicker');
    const text   = document.getElementById('colorText');

    picker.addEventListener('input', () => { text.value = picker.value; });
    text.addEventListener('input',   () => {
      if (/^#[0-9A-Fa-f]{6}$/.test(text.value)) picker.value = text.value;
    });

    const imageInput = document.getElementById('imageInput');
    const preview    = document.getElementById('uploadPreview');
    const zone       = document.getElementById('uploadZone');

    imageInput.addEventListener('change', (e) => {
      const file = e.target.files[0];
      if (!file) return;
      preview.src = URL.createObjectURL(file);
      preview.style.display = 'block';
      const icon = zone.querySelector('.upload-zone__icon');
      const txt  = zone.querySelector('.upload-zone__text');
      const hint = zone.querySelector('.upload-zone__hint');
      if (icon) icon.style.display = 'none';
      if (txt)  txt.style.display  = 'none';
      if (hint) hint.style.display = 'none';
    });

    lucide.createIcons();
  </script>

</body>
</html>
