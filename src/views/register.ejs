<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AURA — Registro</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

    <div class="auth-page">

        <p class="auth-page__logo">Aura</p>
        <p class="auth-page__subtitle">Únete y construye tu guardarropa digital.</p>

        <form class="auth-form" method="POST" action="/register">
        <input name="name"     type="text"     placeholder="Nombre"     required>
        <input name="email"    type="email"    placeholder="Correo electrónico"    required>
        <input name="password" type="password" placeholder="Contraseña" required>
        <button class="auth-form__btn" type="submit">Crear cuenta</button>
        </form>

        <p class="auth-page__link">
        ¿Ya tienes una cuenta? <a href="/login">Inicia sesión</a>
        </p>

    </div>

</body>
</html>
