<div class="loading-overlay" id="loadingOverlay" aria-hidden="true">
  <div class="loading-overlay__panel" role="status" aria-live="polite">
    <div class="loading-overlay__spinner" aria-hidden="true"></div>
    <h2 class="loading-overlay__title">Processing your garment</h2>
    <p class="loading-overlay__copy">We're optimizing your image for the best wardrobe experience.</p>

    <div class="loading-overlay__progress-bar" aria-hidden="true">
      <div class="loading-overlay__progress" id="loadingProgress"></div>
    </div>

    <p class="loading-overlay__message" id="loadingMessage">Uploading image...</p>
  </div>
</div>
