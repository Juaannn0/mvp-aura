<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AURA — Iniciar sesión</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>

    <div class="auth-page">

        <p class="auth-page__logo">Aura</p>
        <p class="auth-page__subtitle">Tu estilo personal, curado a diario.</p>

        <form class="auth-form" method="POST" action="/login">
        <input name="email"    type="email"    placeholder="Correo electrónico"    required>
        <input name="password" type="password" placeholder="Contraseña" required>
        <button class="auth-form__btn" type="submit">Iniciar sesión</button>
        </form>

        <p class="auth-page__link">
        ¿No tienes una cuenta? <a href="/register">Crea una</a>
        </p>

    </div>

</body>
</html>
